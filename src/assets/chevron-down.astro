---
interface Props {
    size?: number;
    color?: string;
    class?: string;
}
const { size = 24, color = "currentColor", class: className } = Astro.props;
---

<svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke={color}
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
>
    <path d="M19 9l-7 7-7-7"></path>
</svg>
