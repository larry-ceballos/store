---
interface Props {
    size?: number;
    color?: string;
    class?: string;
    strokeWidth?: number;
}
const { size = 24, color = "currentColor", class: className, strokeWidth = 3 } = Astro.props;
---

<svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke={color}
    stroke-width={strokeWidth}
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
>
    <path d="M5 13l4 4L19 7"></path>
</svg>
