---
import Send from "@/src/assets/send.astro";
---

<div class="p-3 bg-white border-t-2 border-border">
    <!-- Hidden file input -->
    <input
        type="file"
        id="image-upload-input"
        multiple
        accept=".jpg,.jpeg,.png,.avif,.webp"
        class="hidden"
    />
    
    <div
        class="relative flex items-end gap-2 bg-gray-50 border-2 border-border rounded-xl focus-within:border-primary focus-within:ring-2 focus-within:ring-primary/20 transition-all p-2"
    >
        <button
            id="upload-image-btn"
            type="button"
            class="p-2 mb-0.5 text-secondary hover:text-primary hover:bg-primary/10 rounded-lg transition-all shrink-0"
            title="Adjuntar imágenes"
        >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
        </button>

        <textarea
            id="chat-input"
            rows="1"
            placeholder="Escribe aquí los detalles del producto..."
            class="w-full bg-transparent border-none focus:outline-none focus:ring-0 resize-none text-sm py-1 px-2 text-text placeholder:text-text-muted"
            style="min-height: 24px; max-height: 120px;"></textarea>
        <button
            id="chat-send-btn"
            type="button"
            class="p-2 mb-0.5 bg-primary hover:bg-accent text-white rounded-lg transition-all flex items-center justify-center shrink-0 disabled:opacity-50 disabled:cursor-not-allowed group"
        >
            <Send
                class="w-4 h-4 group-hover:-translate-y-0.5 group-hover:translate-x-0.5 transition-transform"
            />
        </button>
    </div>
</div>
